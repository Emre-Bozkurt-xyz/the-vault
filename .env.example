DATABASE_URL=postgres://vault:vault@localhost:5432/vault
POSTGRES_PASSWORD=vault

# Auth values are placeholders until Phase 1.
AUTH_SECRET=replace-with-a-generated-secret
NEXTAUTH_URL=http://localhost:3000
